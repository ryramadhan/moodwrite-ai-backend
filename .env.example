# Server
PORT=4000

# Database (Option 1: Single DATABASE_URL - RECOMMENDED for Render/Neon)
# Get this from your PostgreSQL provider (Render/Neon/Supabase)
DATABASE_URL=postgresql://username:password@host:port/database_name

# Database (Option 2: Separate variables - for local development)
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=moodwrite_db

# AI Provider: gemini (only option currently supported)
AI_PROVIDER=gemini

# Google Gemini API Key
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model (optional - will fallback to defaults)
GEMINI_MODEL=gemini-1.5-flash-latest

# Fallback to mock when quota/billing error (true/false)
AI_FALLBACK_MOCK=true

# Authentication Settings
# JWT Secret (generate random string, min 32 chars)
JWT_SECRET=your_jwt_secret_key_here_min_32_characters_long
JWT_EXPIRES_IN=7d

# Google OAuth (for Google Login)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Frontend URL (for OAuth callback & email links)
FRONTEND_URL=http://localhost:5173

# Email SMTP (for forgot password)
# Gmail example: smtp.gmail.com, Outlook: smtp.office365.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
